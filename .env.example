# ---- App ----
# Required: signs login sessions (JWT). Use a long random string.
AUTH_SECRET=change-me-to-a-long-random-secret
# Optional: only THIS email can open /admin. Empty = any logged-in user is admin.
ADMIN_EMAIL=

# ---- Supabase (Project Settings -> API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server only — never commit this:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Facebook login (optional real OAuth; the demo button works without these) ----
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
